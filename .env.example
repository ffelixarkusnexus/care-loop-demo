# Copy to .env.local and fill in. NEVER commit real values — .env* is gitignored.

# --- Supabase ---------------------------------------------------------------
# For the local stack, run `npx supabase start` and copy the printed values
# (API URL + anon key + service_role key). `npx supabase status` reprints them.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-local-anon-key

# Server-only. Bypasses RLS — never expose to the browser. Used by the scheduled
# workflow path (ADR-0006) and by tests/rls.test.ts to set up the cross-tenant fixture.
SUPABASE_SERVICE_ROLE_KEY=your-local-service-role-key

# --- Anthropic (Phase 3 edge function) --------------------------------------
# Set as a Supabase Edge Function secret in deployment; here for local reference.
ANTHROPIC_API_KEY=sk-ant-your-key
